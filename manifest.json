{
  "manifest_version": 3,
  "name": "AI Sidebar",
  "version": "1.0.0",
  "description": "ChatGPT, Claude, and Gemini in a Chrome side panel.",
  "permissions": ["sidePanel", "declarativeNetRequest", "tabs", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "AI Sidebar",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "commands": {
    "toggle-sidebar": {
      "description": "Open or close the AI sidebar",
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      }
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_framing",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["chatgpt icon.png", "claude icon 128.png", "gemini icon.png"]
    }
  ]
}
